{
  "name": "0xrss",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/js/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "electron:dev": "concurrently --kill-others \"next dev --turbopack\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && bun run scripts/build-electron.js",
    "electron:pack": "electron-builder --dir",
    "electron:dist:mac": "electron-builder --mac",
    "electron:dist:linux": "electron-builder --linux AppImage:pacman",
    "cf:dev": "npx wrangler pages dev .vercel/output/static --compatibility-flag nodejs_compat",
    "cf:build": "npx @cloudflare/next-on-pages",
    "cf:deploy": "npx @cloudflare/next-on-pages && npx wrangler pages deploy .vercel/output/static",
    "cf:d1:create": "npx wrangler d1 create 0xrss-db",
    "cf:d1:migrate": "npx wrangler d1 migrations apply 0xrss-db"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@mozilla/readability": "^0.6.0",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "duck-duck-scrape": "^2.2.7",
    "jose": "^6.2.2",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "ollama": "^0.6.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260417.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
