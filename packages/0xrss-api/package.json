    "queue:create": "wrangler queues create feed-fetch-queue",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@noble/curves": "^2.2.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4",
    "jose": "^6.2.2",
    "linkedom": "^0.18.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5",
    "vitest": "^4.1.4",
    "wrangler": "^4"
  }
}