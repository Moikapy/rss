{
  "name": "0xrss-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply 0xrss-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply 0xrss-db --remote",
    "db:migrate:prod": "wrangler d1 migrations apply 0xrss-db --remote",
